# Frontend .gitignore

# Firebase credentials (NEVER commit these!)
js/config.js
firebase-init.json

# Environment variables
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts
dist/
build/
*.zip

# Temporary files
*.tmp
*.log
*.cache

# Node modules (if using build tools)
node_modules/
npm-debug.log

# Test coverage
coverage/
.nyc_output/

# Local Firebase emulator
firebase-debug.log
.firebase/
